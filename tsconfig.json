{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["es6", "dom"],
    "skipLibCheck": true,
    "module": "commonjs",
    "experimentalDecorators": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "Schema",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "plugins": [
      { "transform": "ts-transformer-keys/transformer" }
    ]
  },
  "include": ["src", "tests"],
  "exclude": ["dist", "Schema", "node_modules"]
}
